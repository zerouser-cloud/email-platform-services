# ===========================================
# Email Platform — Environment Variables
# ===========================================
# Copy to .env for local development
# Copy to .env.docker for Docker Compose
# ===========================================

# --- HTTP Ports ---
GATEWAY_PORT=3000
AUTH_PORT=3001
SENDER_PORT=3002
PARSER_PORT=3003
AUDIENCE_PORT=3004
NOTIFIER_PORT=3005

# --- gRPC URLs ---
# Local dev: 0.0.0.0:<port>
# Docker: <service-name>:<port>
AUTH_GRPC_URL=0.0.0.0:50051
SENDER_GRPC_URL=0.0.0.0:50052
PARSER_GRPC_URL=0.0.0.0:50053
AUDIENCE_GRPC_URL=0.0.0.0:50054

# --- Infrastructure ---
MONGODB_URI=mongodb://localhost:27017/email-platform
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Cross-Cutting ---
LOG_LEVEL=info
LOG_FORMAT=pretty

# NODE_ENV: application environment (development | production | test)
# Production deployments MUST set NODE_ENV=production explicitly.
NODE_ENV=development

# CORS_ORIGINS: Comma-separated allowed origins
# WARNING: Wildcard "*" is REJECTED in production (NODE_ENV=production).
# Production example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# --- Resilience ---
# Retry configuration for service connection attempts.
# Values below are defaults; override only if needed.
# RETRY_MAX_RETRIES=5
# RETRY_BASE_DELAY_MS=200
# RETRY_MAX_DELAY_MS=5000

# --- Production Hardening ---
GRPC_DEADLINE_MS=5000
RATE_LIMIT_BURST_TTL=1000
RATE_LIMIT_BURST_LIMIT=10
RATE_LIMIT_SUSTAINED_TTL=60000
RATE_LIMIT_SUSTAINED_LIMIT=100
