# ===========================================
# Email Platform — Environment Variables
# ===========================================
# Copy to .env for local development
# Copy to .env.docker for Docker Compose
# ===========================================

# --- HTTP Ports ---
GATEWAY_PORT=3000
AUTH_PORT=3001
SENDER_PORT=3002
PARSER_PORT=3003
AUDIENCE_PORT=3004
NOTIFIER_PORT=3005

# --- gRPC URLs ---
# Local dev: 0.0.0.0:<port>
# Docker: <service-name>:<port>
AUTH_GRPC_URL=0.0.0.0:50051
SENDER_GRPC_URL=0.0.0.0:50052
PARSER_GRPC_URL=0.0.0.0:50053
AUDIENCE_GRPC_URL=0.0.0.0:50054

# --- Infrastructure ---
# Local dev: localhost hostnames
# Docker: service-name hostnames (postgres, redis, rabbitmq, minio)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_platform
# PostgreSQL container credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=email_platform
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672
# MinIO container credentials (used by docker-compose.infra.yml, not by application)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=email-platform
STORAGE_REGION=us-east-1

# --- Cross-Cutting ---
LOG_LEVEL=info
# Local dev: pretty, Docker: json
LOG_FORMAT=pretty
# CORS_ORIGINS: Comma-separated allowed origins
# WARNING: Wildcard "*" is REJECTED when CORS_STRICT=true.
# Production example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*
CORS_STRICT=false

# --- Proto path ---
# Local dev: packages/contracts/proto (relative from repo root)
# Docker: /app/proto (copied into container)
PROTO_DIR=packages/contracts/proto

# --- Production Hardening ---
GRPC_DEADLINE_MS=5000
RATE_LIMIT_BURST_TTL=1000
RATE_LIMIT_BURST_LIMIT=10
RATE_LIMIT_SUSTAINED_TTL=60000
RATE_LIMIT_SUSTAINED_LIMIT=100
