{
  "name": "email-platform",
  "private": true,
  "version": "0.0.1",
  "description": "Email Platform — microservices in monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenv -e .env -- turbo run dev",
    "start": "dotenv -e .env -- turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "eslint 'apps/*/src/**/*.ts' 'packages/*/src/**/*.ts' --fix",
    "typecheck": "turbo run typecheck",
    "check-arch": "bash scripts/check-architecture.sh",
    "generate:contracts": "pnpm --filter @email-platform/contracts run generate",
    "infra:up": "docker compose -f infra/docker-compose.infra.yml -f infra/docker-compose.dev-ports.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.infra.yml -f infra/docker-compose.dev-ports.yml down",
    "docker:up": "docker compose -f infra/docker-compose.yml up --build",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.0.0",
    "turbo": "^2.8.14"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "grpc-tools",
      "protobufjs"
    ]
  }
}
